# App
VITE_APP_BASE=/
VITE_APP_SERVER=http://127.0.0.1:8181
VITE_APP_WEB_SOCKET_SERVER=ws://127.0.0.1:8181
VITE_APP_MODE=development
VITE_APP_DEBUG_ENABLED=true
VITE_APP_XDEBUG_ENABLED=false
VITE_APP_CONSOLE_ENABLED=false
# OAuth
VITE_APP_OAUTH_ENABLED=true
VITE_APP_OAUTH_CLIENT_ID=webapp
VITE_APP_OAUTH_CLIENT_SECRET=webapp
